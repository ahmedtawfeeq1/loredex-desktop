{
  "name": "loredex-desktop",
  "version": "0.1.0",
  "description": "Loredex Desktop — macOS reader and control surface for loredex vaults",
  "type": "module",
  "private": true,
  "license": "MIT",
  "main": "out/main/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "build": "npm run typecheck && electron-vite build",
    "dist": "electron-vite build && electron-builder --mac --arm64"
  },
  "dependencies": {
    "loredex": "file:../loredex",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "electron-vite": "4.0.1",
    "typescript": "5.9.3",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  }
}
