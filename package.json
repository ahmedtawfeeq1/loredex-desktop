{
  "name": "loredex-desktop",
  "version": "0.9.4-agentops.5",
  "description": "Loredex Desktop — macOS reader and control surface for loredex vaults",
  "type": "module",
  "private": true,
  "license": "MIT",
  "main": "out/main/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "predev": "node scripts/prepare-electron-natives.mjs",
    "postinstall": "node scripts/fix-pty-spawn-helper.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:e2e": "vitest run -c vitest.e2e.config.ts",
    "build": "npm run typecheck && electron-vite build",
    "dist": "electron-vite build && electron-builder --mac --arm64",
    "postdist": "node scripts/prepare-electron-natives.mjs"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "0.59.0",
    "@agentclientprotocol/codex-acp": "1.1.4",
    "@agentclientprotocol/sdk": "1.2.1",
    "@codemirror/commands": "6.10.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "6.12.4",
    "@codemirror/search": "6.7.1",
    "@codemirror/state": "6.7.1",
    "@codemirror/view": "6.43.6",
    "@lezer/highlight": "1.2.3",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@parcel/watcher": "2.5.4",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/xterm": "6.0.0",
    "better-sqlite3": "12.11.1",
    "loredex": "file:vendor/loredex-2.9.0-agentops.tgz",
    "node-pty": "1.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rehype-highlight": "7.0.2",
    "rehype-react": "8.0.0",
    "rehype-sanitize": "6.0.0",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "unified": "11.0.5",
    "unist-util-visit": "5.0.0",
    "zod": "^4.4.3",
    "zustand": "5.0.8"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "electron-vite": "4.0.1",
    "jsdom": "^27.4.0",
    "typescript": "5.9.3",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  },
  "author": "Ahmed Tawfeeq <loopx.tech1@gmail.com>",
  "homepage": "https://github.com/ahmedtawfeeq1/loredex-desktop",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmedtawfeeq1/loredex-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/ahmedtawfeeq1/loredex-desktop/issues"
  }
}
